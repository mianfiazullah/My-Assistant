{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a LESCO field employee or admin.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "name": { "type": "string", "description": "The full name of the employee." },
        "email": { "type": "string", "format": "email", "description": "The official email of the employee." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the employee." },
        "expiryDate": { "type": "string", "format": "date-time", "description": "The date when the user's access expires." },
        "subDivision": { "type": "string", "description": "The sub-division where the employee is assigned." }
      },
      "required": ["uid", "name", "email", "role", "expiryDate"]
    },
    "DetectionCase": {
      "title": "DetectionCase",
      "description": "Represents a single electricity theft detection case.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the case." },
        "userId": { "type": "string", "description": "The ID of the employee who recorded the case." },
        "employeeName": { "type": "string", "description": "The name of the employee." },
        "employeeDesignation": { "type": "string", "description": "The designation of the employee." },
        "photoUrl": { "type": "string", "description": "The URL of the uploaded evidence photo." },
        "billData": {
          "type": "object",
          "properties": {
            "consumerName": { "type": "string" },
            "address": { "type": "string" },
            "referenceNumber": { "type": "string" },
            "unitsConsumed": { "type": "number" },
            "amountDue": { "type": "number" },
            "billingMonth": { "type": "string" },
            "sanctionedLoad": { "type": "string" },
            "connectionType": { "type": "string" },
            "customerId": { "type": "string" }
          }
        },
        "dateOfChecking": { "type": "string" },
        "detectionDate": { "type": "string", "format": "date-time" },
        "discrepancy": { "type": "array", "items": { "type": "string" } },
        "checkedBy": { "type": "array", "items": { "type": "string" } },
        "meterType": { "type": "string" },
        "capacity": { "type": "string" },
        "presentReading": { "type": "string" },
        "email": { "type": "string" },
        "mobileNo": { "type": "string" },
        "meterMake": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "sanctionLoad": { "type": "string" },
        "customerId": { "type": "string" },
        "tariff": { "type": "string" },
        "witnesses": { "type": "array", "items": { "type": "string" } },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "firNumber": { "type": "string" },
        "noOfAC": { "type": "string" },
        "acType": { "type": "string" }
      },
      "required": ["userId", "employeeName", "employeeDesignation", "photoUrl", "billData", "detectionDate", "discrepancy", "checkedBy", "meterType", "capacity", "presentReading", "email", "mobileNo", "meterMake", "name", "address", "sanctionLoad", "customerId", "tariff", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/cases/{caseId}": {
      "schema": "DetectionCase",
      "description": "Collection of all detection cases."
    },
    "/feederReadings/{readingId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "feederName": { "type": "string" },
          "reading": { "type": "number" },
          "date": { "type": "string" }
        }
      },
      "description": "Collection of feeder readings recorded by employees."
    }
  }
}
